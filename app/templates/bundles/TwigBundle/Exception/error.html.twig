{% extends 'base.html.twig' %}

{% block title %}Error {{ status_code }}{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="text-center">
        <h1 class="display-1 fw-bold text-secondary">{{ status_code }}</h1>
        <p class="fs-4 fw-semibold mb-2">{{ status_text }}</p>
        <p class="text-muted mb-4">Something went wrong. Please try again later.</p>
        <a href="{{ path('home') }}" class="btn btn-primary">Back to home</a>
    </div>
</div>
{% endblock %}